# Copy to infra/airflow.env and fill in real values.
# This file is loaded by docker-compose as env_file.
# NEVER commit infra/airflow.env to version control.

# ---- Airflow core ----
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__FERNET_KEY=          # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__WEBSERVER__SECRET_KEY=     # any random string, e.g. openssl rand -hex 32
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false

# ---- Database (postgres service defined in docker-compose) ----
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# ---- Email alerts (optional) ----
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_STARTTLS=true
AIRFLOW__SMTP__SMTP_SSL=false
AIRFLOW__SMTP__SMTP_USER=           # your Gmail address
AIRFLOW__SMTP__SMTP_PASSWORD=       # Gmail App Password
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_MAIL_FROM=      # your Gmail address

# ---- BiciMAD project settings ----
BICIMAD_GCP_PROJECT=                # your GCP project ID (e.g. bicimad-prod-2024)
BICIMAD_GCP_REGION=europe-west1     # region for Cloud Run jobs
BICIMAD_GCS_BUCKET=                 # e.g. bicimad-data-your-project-id
BICIMAD_BQ_DATASET=bicimad

# ---- MLflow ----
BICIMAD_MLFLOW_TRACKING_URI=http://mlflow:5000
BICIMAD_MLFLOW_MODEL_NAME=bicimad-forecast
BICIMAD_MLFLOW_PROD_ALIAS=prod
BICIMAD_MLFLOW_EXPERIMENT=bicimad-demand-forecast

# ---- GCP credentials ----
# Point to the service account key mounted inside the container.
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/keys/gcp-key.json

# ---- Airflow GCP connection (alternative to airflow-init approach) ----
# Defining this env var registers the connection without needing a DB entry.
# Uncomment if you prefer this over letting airflow-init create it.
# AIRFLOW_CONN_GOOGLE_CLOUD_DEFAULT=google-cloud-platform://?key_path=%2Fopt%2Fairflow%2Fkeys%2Fgcp-key.json
